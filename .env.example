# ─────────────────────────────────────────────────────────────────────────────
# The Global Briefing — Environment Variables Template
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your real values below
# 3. Never commit .env to Git — it is already listed in .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── AI / APIs (Required) ─────────────────────────────────────────────────────
# Get your free Groq key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Get your free NewsAPI key at: https://newsapi.org
NEWSAPI_KEY=your_newsapi_key_here

# ── Auth (Required) ───────────────────────────────────────────────────────────
# Make up any long random string — used to sign JWT tokens
JWT_SECRET=change_this_to_a_long_random_secret_string

# ── Database (defaults work for local Docker) ─────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_EXTERNAL_PORT=5433

# ── Airflow (defaults work for local Docker) ──────────────────────────────────
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__WEBSERVER__WORKERS=2
AIRFLOW__CORE__LOAD_EXAMPLES=False
# Generate a Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=your_fernet_key_here

# ── Email / Newsletter (Optional) ─────────────────────────────────────────────
# Get a free Resend key at: https://resend.com
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ── Ports (defaults work for local Docker) ────────────────────────────────────
FRONTEND_PORT=3000
AIRFLOW_PORT=8081
